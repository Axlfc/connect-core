LLM_HOST      = "127.0.0.1"
LLM_PORT      = 8000
LLM_PATH      = "/v1/chat/completions"
TTS_ENDPOINT  = "http://127.0.0.1:8880/v1/audio/speech"
MIN_LEN       = 60
VOICE_FILTERS = (
    "highpass=f=80,"
    "equalizer=f=170:width_type=o:width=2:g=2.5,"
    "equalizer=f=340:width_type=o:width=1.5:g=1.5,"
    "equalizer=f=3000:width_type=o:width=1.5:g=1.5,"
    "equalizer=f=10000:width_type=o:width=2:g=2,"
    "aecho=0.85:0.15:50:0.15,"
    "chorus=0.7:0.9:55:0.4:0.25:2,"
    "loudnorm"
)

