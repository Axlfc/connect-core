import sys, json, threading, time, re, subprocess, tempfile, os
import http.client, urllib.request, urllib.error

# ---
if len(sys.argv) < 2:
    print("Uso: cogt 'tu mensaje' [modelo] [voz]")
    sys.exit(1)

PROMPT        = sys.argv[1]
MODEL         = sys.argv[2] if len(sys.argv) > 2 else "cognito"
