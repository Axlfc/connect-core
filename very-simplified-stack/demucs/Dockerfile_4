FROM nvidia/cuda:12.6.2-base-ubuntu22.04

ENV PYTHONUNBUFFERED=1 \
    UV_PROJECT_ENVIRONMENT=/usr/local

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential ffmpeg git python3 python3-pip libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

# Instalamos demucs y las dependencias de la API con uv
RUN uv pip install --system demucs fastapi uvicorn python-multipart

# Descarga el modelo HTDemucs de forma limpia
RUN python3 -c "from demucs.pretrained import get_model; get_model('htdemucs')"

WORKDIR /app
COPY main.py .
EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
